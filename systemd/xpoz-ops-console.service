[Unit]
Description=Xpoz Ops Console
After=network.target

[Service]
Type=simple
WorkingDirectory=/root/projects/xpoz
EnvironmentFile=/root/projects/xpoz/systemd/xpoz-ops-console.env
Environment=PYTHONPATH=/root/projects/xpoz/.deps:/root/projects/xpoz
PassEnvironment=ANTHROPIC_API_KEY
ExecStart=/usr/bin/python3 -m uvicorn ops_console.app:app --host 0.0.0.0 --port 9004
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
